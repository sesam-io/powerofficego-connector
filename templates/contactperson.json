[
  {
    "_id": "{{@ system @}}-{{@ datatype @}}-share",
    "add_namespaces": false,
    "batch_size": 1,
    "compaction": {
      "keep_versions": 100
    },
    "exclude_completeness": [
      "{{@ system @}}-{{@ datatype @}}-share"
    ],
    "namespaced_identifiers": false,
    "sink": {
      "deletion_tracking": false,
      "set_initial_offset": "onload"
    },
    "source": {
      "dataset": "{{@ system @}}-{{@ datatype @}}-transform",
      "type": "dataset"
    },
    "transform": {
      "properties": {
        "operation_delete": "alternate_delete",
        "operation_delete_properties": {
          "datatype1": "Customer",
          "datatype2": "Contact"
        },
        "operation_insert": "alternate_insert",
        "operation_insert_properties": {
          "datatype1": "Customer",
          "datatype2": "Contact"
        },
        "operation_lookup": "alternate_lookup",
        "operation_lookup_properties": {
          "datatype1": "Customer",
          "datatype2": "Contact"
        },
        "operation_update": "alternate_update",
        "operation_update_properties": {
          "datatype1": "Customer",
          "datatype2": "Contact"
        },
        "primary_key": "id",
        "rest_system": "{{@ system @}}",
        "share_dataset": "{{@ system @}}-{{@ datatype @}}-share"
      },
      "template": "transform-share-rest",
      "type": "template"
    },
    "type": "pipe"
  },
  {
    "_id": "{{@ system @}}-{{@ datatype @}}-collect",
    "exclude_completeness": [
      "{{@ system @}}-{{@ datatype @}}-share"
    ],
    "namespaced_identifiers": false,
    "source": {
      "id_expression": "{{ id }}",
      "operation": "alternate_list",
      "payload_property": "data",
      "properties": {
        "datatype": "partycontactperson",
        "since_param": "LastChanged"
      },
      "since_property_name": "since",
      "supports_since": true,
      "system": "{{@ system @}}",
      "type": "rest",
      "updated_expression": "{{ lastChanged|truncate(10, True, '') }}"
    },
    "transform": {
      "properties": {
        "primary_key": "id",
        "share_dataset": "{{@ system @}}-{{@ datatype @}}-share"
      },
      "template": "transform-collect-rest",
      "type": "template"
    },
    "type": "pipe"
  }
]